<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>BIRD VIEW AR</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Noto+Sans+JP:wght@300;400&display=swap');

  :root {
    --sky: #0a0f1e;
    --horizon: #0d2137;
    --accent: #00e5ff;
    --accent2: #39ff14;
    --warn: #ff6b35;
    --text: #c8e6f5;
    --grid: rgba(0,229,255,0.12);
    --panel: rgba(5,20,40,0.82);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: var(--sky);
    font-family: 'Share Tech Mono', monospace;
    color: var(--text);
    overflow: hidden;
    height: 100dvh;
    width: 100vw;
    user-select: none;
  }

  /* ── Camera layer ── */
  #camera-feed {
    position: fixed; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
    display: none;
  }

  /* ── Three.js canvas ── */
  #three-canvas {
    position: fixed; inset: 0;
    width: 100%; height: 100%;
    z-index: 1;
    opacity: 0;
    transition: opacity 1.2s ease;
    touch-action: none;
  }
  #three-canvas.visible { opacity: 1; }

  /* ── Scan overlay ── */
  #scan-overlay {
    position: fixed; inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(5,10,20,0.6);
    backdrop-filter: blur(2px);
    transition: opacity 0.8s ease;
  }
  #scan-overlay.hidden { opacity:0; pointer-events:none; }

  .scan-frame {
    position: relative;
    width: min(72vw, 300px);
    aspect-ratio: 1;
    margin-bottom: 2.4rem;
  }
  .scan-frame::before,
  .scan-frame::after {
    content:'';
    position:absolute;
    width:36%; height:36%;
    border-color: var(--accent);
    border-style: solid;
    border-width: 0;
  }
  .scan-frame::before { top:0; left:0; border-top-width:3px; border-left-width:3px; border-radius:4px 0 0 0; }
  .scan-frame::after  { bottom:0; right:0; border-bottom-width:3px; border-right-width:3px; border-radius:0 0 4px 0; }
  .scan-frame-tr, .scan-frame-bl {
    position:absolute;
    width:36%; height:36%;
    border-color: var(--accent);
    border-style: solid;
    border-width: 0;
  }
  .scan-frame-tr { top:0; right:0; border-top-width:3px; border-right-width:3px; border-radius:0 4px 0 0; }
  .scan-frame-bl { bottom:0; left:0; border-bottom-width:3px; border-left-width:3px; border-radius:0 0 0 4px; }

  .scan-line {
    position: absolute;
    left: 6%; right: 6%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    box-shadow: 0 0 12px var(--accent);
    animation: scanMove 2.4s ease-in-out infinite;
  }
  @keyframes scanMove {
    0%,100% { top: 8%; opacity:0.4; }
    50% { top: 88%; opacity:1; }
  }

  .scan-label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-align: center;
    line-height: 2;
    margin-bottom: 1rem;
  }

  .scan-status {
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: var(--text);
    text-align: center;
    animation: pulse 1.8s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:0.5} 50%{opacity:1} }

  /* ── Permission screen ── */
  #permission-screen {
    position: fixed; inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 2rem;
    background: var(--sky);
  }
  #permission-screen.hidden { display:none; }

  .logo {
    font-size: 2.2rem;
    letter-spacing: 0.3em;
    color: var(--accent);
    text-shadow: 0 0 30px var(--accent);
    animation: glitch 4s infinite;
  }
  @keyframes glitch {
    0%,94%,100% { text-shadow: 0 0 30px var(--accent); transform:none; }
    95% { text-shadow: -3px 0 var(--warn), 3px 0 var(--accent2); transform:skewX(-1deg); }
    97% { text-shadow: 3px 0 var(--warn), -3px 0 var(--accent2); transform:skewX(1deg); }
  }

  .sub-label {
    font-family: 'Noto Sans JP', sans-serif;
    font-weight: 300;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: rgba(200,230,245,0.6);
    text-align: center;
    line-height: 2;
  }

  .start-btn {
    margin-top: 1rem;
    padding: 1rem 2.8rem;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.9rem;
    letter-spacing: 0.25em;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: color 0.3s;
  }
  .start-btn::before {
    content:'';
    position:absolute;
    inset:0;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
    z-index: -1;
  }
  .start-btn:active::before { transform:scaleX(1); }
  .start-btn:active { color: var(--sky); }

  /* ── HUD overlay ── */
  #hud {
    position: fixed;
    z-index: 5;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1s ease 0.5s;
  }
  #hud.visible { opacity:1; }

  .hud-corner {
    position: absolute;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    color: rgba(0,229,255,0.65);
    line-height: 1.8;
  }
  .hud-tl { top:1.4rem; left:1.4rem; }
  .hud-tr { top:1.4rem; right:1.4rem; text-align:right; }
  .hud-bl { bottom:2rem; left:1.4rem; }

  .hud-alt {
    position: absolute;
    right: 1.4rem;
    bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .hud-alt-bar {
    width: 3px;
    height: 60px;
    background: rgba(0,229,255,0.2);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }
  .hud-alt-fill {
    position: absolute;
    bottom:0; left:0; right:0;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    transition: height 0.4s ease;
    height: 70%;
  }
  .hud-alt-label {
    font-size: 0.58rem;
    color: var(--accent);
    writing-mode: vertical-rl;
    letter-spacing: 0.1em;
  }

  /* compass */
  .hud-compass {
    position: absolute;
    top: 1.2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .compass-ring {
    width: 44px; height: 44px;
    border: 1px solid rgba(0,229,255,0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .compass-needle {
    position: absolute;
    width: 2px;
    height: 16px;
    background: linear-gradient(to bottom, var(--warn), transparent);
    border-radius: 1px;
    transform-origin: bottom center;
    top: 5px; left: 50%;
    margin-left: -1px;
  }
  .compass-n {
    font-size: 0.55rem;
    color: var(--warn);
    letter-spacing: 0.1em;
  }

  /* ── Recognition success flash ── */
  #success-flash {
    position: fixed; inset:0;
    z-index:15;
    background: var(--accent);
    opacity: 0;
    pointer-events: none;
  }

  /* ── Instruction pill ── */
  #instruction {
    position: fixed;
    bottom: 5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 6;
    background: var(--panel);
    border: 1px solid rgba(0,229,255,0.25);
    padding: 0.55rem 1.2rem;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    color: rgba(200,230,245,0.7);
    border-radius: 2px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease;
    white-space: nowrap;
  }
  #instruction.visible { opacity:1; }

  /* scan grid bg */
  .bg-grid {
    position: fixed; inset:0;
    background-image:
      linear-gradient(var(--grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid) 1px, transparent 1px);
    background-size: 40px 40px;
    z-index: 0;
    animation: gridScroll 8s linear infinite;
  }
  @keyframes gridScroll { from{background-position:0 0} to{background-position:40px 40px} }
</style>
</head>
<body>

<div class="bg-grid" id="bg-grid"></div>
<video id="camera-feed" autoplay playsinline muted></video>
<canvas id="three-canvas"></canvas>

<!-- Permission / Start Screen -->
<div id="permission-screen">
  <div class="logo">BIRD VIEW</div>
  <div class="sub-label">
    スマートフォンのカメラで室内を映してください<br>
    床面を認識すると鳥瞰モードに切り替わります
  </div>
  <button class="start-btn" onclick="startAR()">▶ START SCAN</button>
</div>

<!-- Scan Overlay -->
<div id="scan-overlay" class="hidden">
  <div class="scan-frame">
    <div class="scan-frame-tr"></div>
    <div class="scan-frame-bl"></div>
    <div class="scan-line"></div>
  </div>
  <div class="scan-label">FLOOR SURFACE DETECTION<br>床面にカメラを向けてください</div>
  <div class="scan-status" id="scan-status">SCANNING...</div>
</div>

<!-- Flash -->
<div id="success-flash"></div>

<!-- Three.js Canvas -->
<!-- HUD -->
<div id="hud">
  <div class="hud-tl">
    BIRD VIEW AR<br>
    <span style="color:var(--accent2)">● LIVE</span>
  </div>
  <div class="hud-tr" id="hud-coords">
    ALT: <span id="alt-val">8.0</span>m<br>
    θ: <span id="theta-val">45</span>°
  </div>
  <div class="hud-compass">
    <div class="compass-ring">
      <div class="compass-needle" id="compass-needle"></div>
    </div>
    <div class="compass-n">N</div>
  </div>
  <div class="hud-bl">
    DRAG → ORBIT<br>
    PINCH → ZOOM
  </div>
  <div class="hud-alt">
    <div class="hud-alt-label">ALT</div>
    <div class="hud-alt-bar"><div class="hud-alt-fill" id="alt-bar"></div></div>
  </div>
</div>

<div id="instruction">ドラッグで視点を回転 · ピンチでズーム</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
// ─── State ───────────────────────────────────────────────
let scanActive = false;
let birdViewActive = false;
let scene, camera, renderer;
let isDragging = false;
let lastTouch = {x:0, y:0};
let spherical = { theta: Math.PI/4, phi: Math.PI/3.5, radius: 14 };
let targetSpherical = { ...spherical };
let pinchDist0 = null;
let animFrameId = null;
let compassAngle = 0;

// ─── Start AR ────────────────────────────────────────────
async function startAR() {
  document.getElementById('permission-screen').classList.add('hidden');
  document.getElementById('bg-grid').style.display = 'none';

  try {
    const stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width:{ideal:1280}, height:{ideal:720} }
    });
    const video = document.getElementById('camera-feed');
    video.srcObject = stream;
    video.style.display = 'block';
  } catch(e) {
    // No camera – proceed with demo mode
  }

  document.getElementById('scan-overlay').classList.remove('hidden');
  scanActive = true;
  simulateScan();
}

// ─── Simulate floor detection ────────────────────────────
function simulateScan() {
  const statuses = [
    'SCANNING...', 'ANALYZING SURFACE...', 'DETECTING PLANES...',
    'FLOOR PLANE FOUND', 'MAPPING ROOM...', 'CALIBRATING...'
  ];
  let i = 0;
  const el = document.getElementById('scan-status');

  const tick = setInterval(() => {
    el.textContent = statuses[i % statuses.length];
    i++;
    if (i >= statuses.length) {
      clearInterval(tick);
      onFloorDetected();
    }
  }, 700);
}

// ─── Floor detected → transition to bird view ────────────
function onFloorDetected() {
  // Flash
  const flash = document.getElementById('success-flash');
  flash.style.opacity = '0.7';
  flash.style.transition = 'opacity 0.12s ease';
  setTimeout(() => {
    flash.style.transition = 'opacity 0.5s ease';
    flash.style.opacity = '0';
  }, 120);

  // Hide scan overlay
  setTimeout(() => {
    document.getElementById('scan-overlay').classList.add('hidden');
    document.getElementById('camera-feed').style.display = 'none';
    initThreeScene();
    animateBirdFlyIn();
  }, 300);
}

// ─── Three.js scene ──────────────────────────────────────
function initThreeScene() {
  const canvas = document.getElementById('three-canvas');
  renderer = new THREE.WebGLRenderer({ canvas, antialias:true, alpha:true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.1;

  scene = new THREE.Scene();
  scene.background = new THREE.Color(0x060d1a);
  scene.fog = new THREE.FogExp2(0x060d1a, 0.022);

  camera = new THREE.PerspectiveCamera(55, window.innerWidth/window.innerHeight, 0.1, 200);
  camera.position.set(0, 30, 30);
  camera.lookAt(0,0,0);

  buildRoom();
  buildLighting();
  setupControls();

  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth/window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  renderLoop();
}

function buildRoom() {
  const mats = {
    floor: new THREE.MeshStandardMaterial({
      color: 0x1a2635,
      roughness: 0.75,
      metalness: 0.05,
    }),
    wall: new THREE.MeshStandardMaterial({
      color: 0x0e1c2d,
      roughness: 0.9,
      metalness: 0.0,
      side: THREE.BackSide
    }),
    grid: new THREE.MeshBasicMaterial({
      color: 0x00e5ff,
      wireframe: true,
      transparent: true,
      opacity: 0.08
    }),
    furniture: new THREE.MeshStandardMaterial({
      color: 0x152236,
      roughness: 0.6,
      metalness: 0.3
    }),
    glowing: new THREE.MeshStandardMaterial({
      color: 0x00e5ff,
      emissive: 0x00e5ff,
      emissiveIntensity: 0.4,
      roughness: 0.3,
      metalness: 0.6
    }),
    accent: new THREE.MeshStandardMaterial({
      color: 0xff6b35,
      emissive: 0xff6b35,
      emissiveIntensity: 0.3,
      roughness: 0.4
    })
  };

  // Floor
  const floor = new THREE.Mesh(new THREE.PlaneGeometry(20, 16), mats.floor);
  floor.rotation.x = -Math.PI/2;
  floor.receiveShadow = true;
  scene.add(floor);

  // Grid overlay on floor
  const grid = new THREE.GridHelper(20, 20, 0x00e5ff, 0x00e5ff);
  grid.material.transparent = true;
  grid.material.opacity = 0.12;
  grid.position.y = 0.01;
  scene.add(grid);

  // Room box (walls + ceiling - open top for bird view)
  const room = new THREE.Mesh(new THREE.BoxGeometry(20, 8, 16), mats.wall);
  room.position.y = 4;
  scene.add(room);

  // Furniture: sofa
  addBox(scene, -5, 0.4, -4, 4, 0.8, 1.8, mats.furniture);
  addBox(scene, -5, 0.8, -4.7, 4, 1.2, 0.3, mats.furniture); // back
  addBox(scene, -7.0, 0.9, -4, 0.3, 1.0, 1.8, mats.furniture); // armrest L
  addBox(scene, -3.0, 0.9, -4, 0.3, 1.0, 1.8, mats.furniture); // armrest R

  // Coffee table
  addBox(scene, -5, 0.25, -2.2, 2, 0.08, 1, mats.glowing);
  // table legs
  [[-5.8,-2.6],[-4.2,-2.6],[-5.8,-1.8],[-4.2,-1.8]].forEach(([x,z])=>{
    addBox(scene, x, 0.12, z, 0.08, 0.25, 0.08, mats.furniture);
  });

  // Rug
  const rug = new THREE.Mesh(new THREE.PlaneGeometry(5, 3.5),
    new THREE.MeshStandardMaterial({color:0x1e3a5f, roughness:1}));
  rug.rotation.x = -Math.PI/2;
  rug.position.set(-5, 0.005, -2.8);
  scene.add(rug);

  // TV unit
  addBox(scene, -5, 0.3, 5.5, 5, 0.6, 0.5, mats.furniture);
  // TV screen (glowing)
  addBox(scene, -5, 1.2, 5.65, 3.5, 1.8, 0.08, mats.glowing);

  // Desk
  addBox(scene, 5, 0.76, 2, 3.5, 0.06, 1.8, mats.furniture);
  [[-6.3,1.2],[-3.7,1.2],[-6.3,2.8],[-3.7,2.8]].forEach(([x,z])=>{
    addBox(scene, x+11.3, 0.37, z, 0.08, 0.76, 0.08, mats.furniture);
  });
  // Monitor
  addBox(scene, 5, 1.2, 2.8, 1.4, 0.9, 0.06, mats.glowing);

  // Bookshelf
  addBox(scene, 8.5, 1.5, -4, 0.4, 3, 3, mats.furniture);
  [0.2,0.9,1.6,2.3].forEach(y => {
    addBox(scene, 8.5, y, -4, 0.38, 0.06, 2.8,
      new THREE.MeshStandardMaterial({color:0x0d1a28, roughness:0.8}));
  });
  // books
  const bookColors = [0x2a5298,0x8b0000,0x1a6b1a,0x8b6914,0x4a0080];
  for(let i=0;i<15;i++){
    const w = 0.12+Math.random()*0.08;
    addBox(scene, 8.65, 0.4+Math.floor(i/5)*0.7, -4.8+(i%5)*0.52, w, 0.55, 0.4,
      new THREE.MeshStandardMaterial({
        color:bookColors[i%5],
        roughness:0.8,
        emissive:bookColors[i%5],
        emissiveIntensity:0.05
      }));
  }

  // Potted plant
  const plantMat = new THREE.MeshStandardMaterial({color:0x0d3b1a, roughness:0.9});
  const potMat = new THREE.MeshStandardMaterial({color:0x3d1c08, roughness:0.8});
  const pot = new THREE.Mesh(new THREE.CylinderGeometry(0.28,0.22,0.45,12), potMat);
  pot.position.set(7.5, 0.22, -5.5);
  scene.add(pot);
  const plant = new THREE.Mesh(new THREE.SphereGeometry(0.55,10,10), plantMat);
  plant.position.set(7.5, 0.85, -5.5);
  plant.scale.set(1,1.2,1);
  scene.add(plant);

  // Lamp
  const lampBase = new THREE.Mesh(new THREE.CylinderGeometry(0.18,0.22,0.08,12), mats.furniture);
  lampBase.position.set(-7.5, 0.04, -5.5);
  scene.add(lampBase);
  const lampPole = new THREE.Mesh(new THREE.CylinderGeometry(0.04,0.04,1.4,8), mats.furniture);
  lampPole.position.set(-7.5, 0.74, -5.5);
  scene.add(lampPole);
  const lampShade = new THREE.Mesh(new THREE.ConeGeometry(0.42,0.5,16,1,true), mats.furniture);
  lampShade.position.set(-7.5, 1.7, -5.5);
  scene.add(lampShade);

  // Window frames on walls
  // Front wall (z=8) – two windows
  [[-4,4],[ 3,4]].forEach(([x,y])=>{
    const frame = new THREE.Mesh(new THREE.PlaneGeometry(2.2,1.8),
      new THREE.MeshStandardMaterial({
        color:0x00e5ff, emissive:0x003344, emissiveIntensity:1, roughness:0.1
      }));
    frame.position.set(x, y, -7.98);
    scene.add(frame);
  });

  // Accent light strip on ceiling edge
  const stripMat = new THREE.MeshStandardMaterial({
    color:0x00e5ff, emissive:0x00e5ff, emissiveIntensity:1
  });
  [
    [-9.9,7.9,0, 0.05,0.05,15.8],
    [ 9.9,7.9,0, 0.05,0.05,15.8],
    [0,7.9,-7.9, 19.8,0.05,0.05],
    [0,7.9, 7.9, 19.8,0.05,0.05],
  ].forEach(([x,y,z,w,h,d])=>{
    addBox(scene, x, y, z, w, h, d, stripMat);
  });

  // Floor accent line
  const accentLine = new THREE.Mesh(new THREE.PlaneGeometry(0.06,15.8),
    new THREE.MeshStandardMaterial({color:0x39ff14,emissive:0x39ff14,emissiveIntensity:0.6}));
  accentLine.rotation.x = -Math.PI/2;
  accentLine.position.set(-9.5, 0.02, 0);
  scene.add(accentLine);
}

function addBox(scene, x, y, z, w, h, d, mat) {
  const mesh = new THREE.Mesh(new THREE.BoxGeometry(w,h,d), mat);
  mesh.position.set(x, y, z);
  mesh.castShadow = true;
  mesh.receiveShadow = true;
  scene.add(mesh);
  return mesh;
}

function buildLighting() {
  // Ambient
  scene.add(new THREE.AmbientLight(0x0a1628, 3));

  // Main overhead
  const main = new THREE.DirectionalLight(0x9fc8ff, 1.2);
  main.position.set(0, 15, 5);
  main.castShadow = true;
  main.shadow.mapSize.set(2048,2048);
  scene.add(main);

  // Cyan fill
  const fill = new THREE.PointLight(0x00e5ff, 1.8, 25);
  fill.position.set(-5, 6, -3);
  scene.add(fill);

  // Warm accent (lamp area)
  const warm = new THREE.PointLight(0xff9050, 2.5, 8);
  warm.position.set(-7.5, 1.8, -5.5);
  scene.add(warm);

  // TV glow
  const tvGlow = new THREE.PointLight(0x00e5ff, 1.5, 6);
  tvGlow.position.set(-5, 1.5, 5);
  scene.add(tvGlow);

  // Monitor glow
  const monGlow = new THREE.PointLight(0x00e5ff, 1.2, 4);
  monGlow.position.set(5, 1.5, 3);
  scene.add(monGlow);

  // Ceiling strip emitters
  const strip1 = new THREE.RectAreaLight(0x00e5ff, 2, 20, 0.1);
  strip1.position.set(0, 7.8, 0);
  strip1.rotation.x = Math.PI/2;
  scene.add(strip1);
}

// ─── Bird fly-in animation ────────────────────────────────
function animateBirdFlyIn() {
  const canvas = document.getElementById('three-canvas');
  canvas.classList.add('visible');

  // Camera starts close, flies up
  camera.position.set(0, 2, 3);

  const hud = document.getElementById('hud');
  const inst = document.getElementById('instruction');

  let t = 0;
  const dur = 140;
  const flyIn = () => {
    t++;
    const p = easeOutCubic(Math.min(t/dur, 1));
    const targetR = 14;
    const r = 3 + (targetR-3)*p;
    const phi = 0.45 + (Math.PI/3.5 - 0.45)*p;
    const th = Math.PI/4 + (Math.PI/4)*p;
    camera.position.set(
      r * Math.sin(th) * Math.sin(phi),
      r * Math.cos(phi),
      r * Math.cos(th) * Math.sin(phi)
    );
    camera.lookAt(0, 1, 0);

    if(t < dur) requestAnimationFrame(flyIn);
    else {
      spherical = { theta:th, phi, radius:r };
      targetSpherical = { ...spherical };
      birdViewActive = true;
      hud.classList.add('visible');
      setTimeout(() => inst.classList.add('visible'), 400);
      setTimeout(() => inst.classList.remove('visible'), 4000);
    }
  };
  requestAnimationFrame(flyIn);
}

function easeOutCubic(t) { return 1 - Math.pow(1-t, 3); }

// ─── Render loop ─────────────────────────────────────────
function renderLoop() {
  animFrameId = requestAnimationFrame(renderLoop);

  if(birdViewActive) {
    // Smooth follow
    spherical.theta += (targetSpherical.theta - spherical.theta) * 0.1;
    spherical.phi   += (targetSpherical.phi   - spherical.phi)   * 0.1;
    spherical.radius += (targetSpherical.radius - spherical.radius) * 0.1;
    spherical.phi = Math.max(0.12, Math.min(Math.PI/2.1, spherical.phi));
    spherical.radius = Math.max(6, Math.min(30, spherical.radius));

    camera.position.set(
      spherical.radius * Math.sin(spherical.theta) * Math.sin(spherical.phi),
      spherical.radius * Math.cos(spherical.phi),
      spherical.radius * Math.cos(spherical.theta) * Math.sin(spherical.phi)
    );
    camera.lookAt(0, 1, 0);

    // HUD update
    const alt = (spherical.radius * Math.cos(spherical.phi)).toFixed(1);
    const theta = Math.round((spherical.phi * 180/Math.PI));
    document.getElementById('alt-val').textContent = alt;
    document.getElementById('theta-val').textContent = theta;
    document.getElementById('alt-bar').style.height =
      ((spherical.radius - 6) / 24 * 100).toFixed(0) + '%';

    compassAngle -= 0.003;
    document.getElementById('compass-needle').style.transform =
      `rotate(${compassAngle * 180/Math.PI}deg)`;
  }

  renderer.render(scene, camera);
}

// ─── Touch / Mouse controls ───────────────────────────────
function setupControls() {
  const canvas = document.getElementById('three-canvas');

  // Mouse
  canvas.addEventListener('mousedown', e => {
    isDragging = true;
    lastTouch = {x: e.clientX, y: e.clientY};
  });
  window.addEventListener('mousemove', e => {
    if(!isDragging) return;
    const dx = e.clientX - lastTouch.x;
    const dy = e.clientY - lastTouch.y;
    targetSpherical.theta -= dx * 0.007;
    targetSpherical.phi   -= dy * 0.005;
    lastTouch = {x: e.clientX, y: e.clientY};
  });
  window.addEventListener('mouseup', () => isDragging = false);
  canvas.addEventListener('wheel', e => {
    targetSpherical.radius += e.deltaY * 0.02;
  });

  // Touch
  canvas.addEventListener('touchstart', e => {
    if(e.touches.length === 1) {
      isDragging = true;
      lastTouch = {x: e.touches[0].clientX, y: e.touches[0].clientY};
    } else if(e.touches.length === 2) {
      isDragging = false;
      pinchDist0 = getPinchDist(e);
    }
  }, {passive:true});

  canvas.addEventListener('touchmove', e => {
    if(e.touches.length === 1 && isDragging) {
      const dx = e.touches[0].clientX - lastTouch.x;
      const dy = e.touches[0].clientY - lastTouch.y;
      targetSpherical.theta -= dx * 0.007;
      targetSpherical.phi   -= dy * 0.005;
      lastTouch = {x: e.touches[0].clientX, y: e.touches[0].clientY};
    } else if(e.touches.length === 2 && pinchDist0 !== null) {
      const d = getPinchDist(e);
      targetSpherical.radius *= pinchDist0 / d;
      pinchDist0 = d;
    }
  }, {passive:true});

  canvas.addEventListener('touchend', () => {
    isDragging = false;
    pinchDist0 = null;
  }, {passive:true});
}

function getPinchDist(e) {
  const dx = e.touches[0].clientX - e.touches[1].clientX;
  const dy = e.touches[0].clientY - e.touches[1].clientY;
  return Math.sqrt(dx*dx + dy*dy);
}
